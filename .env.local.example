# ─── Keystatic CMS ───────────────────────────────────────────────────────────
#
# LOCAL DEVELOPMENT: No env vars needed — Keystatic runs in "local" mode.
#
# PRODUCTION (Vercel): Set these to use Keystatic in "github" mode.
# Articles are edited in the Keystatic UI and saved as PRs on GitHub.
#
# 1. Create a GitHub OAuth App at https://github.com/settings/developers
#    - Homepage URL: https://amandanasario.com
#    - Callback URL: https://amandanasario.com/api/keystatic/github/oauth/callback
#
# 2. Set the values below in your Vercel project environment variables.

KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=   # any random string, e.g. openssl rand -hex 32
